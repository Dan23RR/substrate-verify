# Example environment file. Copy to `.env` and fill in ONLY if you use the optional legs.
# The core reproducible suite (`python verify_all.py`) needs NO secrets and NO network.
# `.env` itself is gitignored — never commit real values.

# Optional: enable the real isolated-WASM executor path for pyprop subjects (off by default).
# SUBSTRATE_PYPROP_WASI=1

# Optional: an Ethereum JSON-RPC endpoint, ONLY for the live on-chain vault checks.
# Use your own provider key. Leave unset to keep everything offline (live legs then ABSTAIN/skip).
# ETH_RPC_URL=https://your-provider.example/v3/YOUR_PROJECT_KEY
